# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/pairon

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Backend public URL (used for GitHub OAuth callback)
BACKEND_URL=https://your-backend.onrender.com

# Groq AI API Key (get free key from https://console.groq.com)
GROQ_API_KEY=your-groq-api-key

# GitHub OAuth App (create at github.com/settings/developers -> OAuth Apps)
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret